---
const { id, imagen, titulo, autor, precio } = Astro.props;
---

<article class="curso-card">
    <div class="curso-imagen">
        <img src={imagen} alt={titulo} />
        <div class="curso-overlay">
            <span class="curso-badge">$15</span>
        </div>
    </div>

    <div class="curso-info">
        <div class="curso-meta">
            <span class="curso-autor">{autor}</span>
            <div class="curso-estrellas">
                {[1, 2, 3, 4, 5].map(() => <i class="fa-solid fa-star" />)}
            </div>
        </div>

        <h3 class="curso-titulo">{titulo}</h3>
        <span class="accent-line"></span>

        <div class="curso-precio">
            <span class="precio-original">$200</span>
            <span class="precio-actual">${precio}</span>
        </div>

        <button class="btn-primary agregar-carrito" data-id={id} type="button">
            <i class="fa-solid fa-cart-plus"></i>
            Agregar al carrito
        </button>
    </div>
</article>

<style>
    .curso-card {
        background: var(--bg-panel);
        border: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        transition:
            border-color 0.3s,
            transform 0.3s;
        height: 100%;
    }
    .curso-card:hover {
        border-color: var(--gold-border);
        transform: translateY(-4px);
    }

    .curso-imagen {
        position: relative;
        overflow: hidden;
        aspect-ratio: 16 / 9;
    }
    .curso-imagen img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
        filter: brightness(0.85);
    }
    .curso-card:hover .curso-imagen img {
        transform: scale(1.05);
        filter: brightness(0.7);
    }

    .curso-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, #0e0e0ecc 0%, transparent 60%);
    }

    .curso-badge {
        position: absolute;
        top: 0.8rem;
        right: 0.8rem;
        background: var(--gold);
        color: #0e0e0e;
        font-family: var(--font-body);
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        padding: 0.3rem 0.7rem;
    }

    .curso-info {
        padding: 1.4rem;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .curso-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.6rem;
    }

    .curso-autor {
        font-size: 0.65rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .curso-estrellas {
        display: flex;
        gap: 2px;
        color: var(--gold);
    }

    .curso-titulo {
        font-family: var(--font-display);
        font-size: 1.15rem;
        font-weight: 400;
        color: var(--text-main);
        line-height: 1.3;
    }

    .accent-line {
        display: block;
        width: 30px;
        height: 1px;
        background: var(--gold);
        margin: 1rem 0;
    }

    .curso-precio {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        margin-bottom: 1.4rem;
        margin-top: auto;
    }

    .precio-original {
        font-size: 0.75rem;
        color: var(--text-muted);
        text-decoration: line-through;
        letter-spacing: 0.05em;
    }

    .precio-actual {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 300;
        color: var(--gold);
    }

    .btn-primary.agregar-carrito {
        width: 100%;
        justify-content: center;
        font-size: 0.65rem;
        padding: 0.85rem;
    }
</style>
