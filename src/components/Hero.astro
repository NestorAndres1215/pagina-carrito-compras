---

---

<section id="hero" class="hero">
    <div class="hero-bg">
        <div class="hero-grid"></div>
        <div class="hero-glow"></div>
    </div>

    <div class="container">
        <div class="hero-content">
            <p class="section-label fade-up">Plataforma de cursos</p>

            <h1 class="hero-title fade-up fade-up-delay-1">
                Aprende a<br />
                <em>Programar</em>
            </h1>

            <span class="accent-line fade-up fade-up-delay-2"></span>

            <p class="hero-sub fade-up fade-up-delay-2">
                Todos los cursos por solo <strong>$15</strong> — acceso de por vida.
            </p>

            <!-- Buscador -->
            <div class="hero-search fade-up fade-up-delay-3">
                <div class="search-box">
                    <i class="fa-solid fa-magnifying-glass search-icon"></i>
                    <input
                        type="text"
                        id="buscador"
                        placeholder="¿Qué lenguaje quieres aprender?"
                        autocomplete="off"
                    />
                    <button
                        id="submit-buscador"
                        class="btn-primary"
                        type="button"
                    >
                        Buscar
                    </button>
                </div>
                <p class="search-hints">
                    Popular: <a href="#">Python</a> · <a href="#">JavaScript</a> ·
                    <a href="#">Rust</a>
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        min-height: 92vh;
        display: flex;
        align-items: center;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }

    .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(var(--border) 1px, transparent 1px),
            linear-gradient(90deg, var(--border) 1px, transparent 1px);
        background-size: 60px 60px;
        opacity: 0.4;
        mask-image: radial-gradient(
            ellipse 80% 80% at 20% 50%,
            black 30%,
            transparent 100%
        );
    }
    .hero-glow {
        position: absolute;
        top: 50%;
        left: -10%;
        width: 600px;
        height: 600px;
        transform: translateY(-50%);
        background: radial-gradient(circle, #c9a96e18 0%, transparent 70%);
        filter: blur(40px);
    }

    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 640px;
        padding: 6rem 0;
    }

    .hero-title {
        margin-bottom: 0;
        color: var(--text-main);
    }

    .hero-title em {
        font-style: italic;
        color: var(--gold);
    }

    .hero-sub {
        font-size: 0.9rem;
        color: var(--text-soft);
        max-width: 420px;
        margin-bottom: 2.5rem;
    }

    .hero-sub strong {
        color: var(--gold);
        font-weight: 500;
    }

    .hero-search {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .search-box {
        display: flex;
        align-items: center;
        background: var(--bg-panel);
        border: 1px solid var(--border);
        transition: border-color 0.3s;
    }

    .search-box:focus-within {
        border-color: var(--gold);
    }

    .search-icon {
        width: 18px;
        height: 18px;
        color: var(--text-muted);
        flex-shrink: 0;
        margin: 0 1rem;
    }

    .search-box input {
        flex: 1;
        background: none;
        border: none;
        outline: none;
        color: var(--text-main);
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 300;
        letter-spacing: 0.05em;
        padding: 1rem 0;
        caret-color: var(--gold);
    }

    .search-box input::placeholder {
        color: var(--text-muted);
    }

    .search-box .btn-primary {
        padding: 1rem 1.8rem;
        flex-shrink: 0;
        font-size: 0.65rem;
    }

    .search-hints {
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        color: var(--text-muted);
        margin: 0;
    }

    .search-hints a {
        color: var(--text-soft);
        transition: color 0.2s;
    }

    .search-hints a:hover {
        color: var(--gold);
        opacity: 1;
    }
    @media (max-width: 640px) {
        .hero {
            min-height: 85vh;
        }

        .hero-content {
            padding: 4rem 0;
        }

        .search-box {
            flex-direction: column;
            align-items: stretch;
        }

        .search-box input {
            padding: 1rem;
        }

        .search-icon {
            display: none;
        }

        .search-box .btn-primary {
            padding: 1rem;
            justify-content: center;
        }
    }
</style>
